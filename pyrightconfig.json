{
  "include": [
    "server/scripts",
    "data"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    ".venv"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": "server/scripts",
      "extraPaths": [
        "."
      ]
    },
    {
      "root": "."
    }
  ],
  "typeCheckingMode": "basic"
}