  {
    "id": 125,
    "question": "A car dealer bought a second-hand car for N250,000 and spent N70,000 refurbishing it. He then sold the car for N400,000. What is the percentage gain?",
    "option": {
      "a": "60%",
      "b": " 32%",
      "c": "25%",
      "d": "20%",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "c",
    "solution": "Total cost = N(250,000 + 70,000) = N320,000\nSelling price = N400,000 (given)\nGain = SP - CP = N(400,000 - 320,000) = N80,000\nGain % = gain/CP x 100 = (80,000/320,000) x 100\n\nGain % = 25%",
    "examtype": "utme",
    "examyear": "2001"
  },
