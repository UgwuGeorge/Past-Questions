  {
    "id": 595,
    "question": "At what rate will the interest on N400 increases to N24 in 3 years reckoning in simple interest?",
    "option": {
      "a": "3%",
      "b": "2%",
      "c": "5%",
      "d": "4%",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "b",
    "solution": "Using simple interest = P × T × R/100,\n\nwhere: P denoted principal = N400\nT denotes time = 3 years\nR denotes interest rate = ?\n\n24 = 400×3×R/100\n\n24 x 100 = 400 x 3 x R\n\nR = (24 × 100)/(400 × 3)\n\n= 2%",
    "examtype": "utme",
    "examyear": "2010"
  },
