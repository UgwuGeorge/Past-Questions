  {
    "id": 602,
    "question": "Solve for x and y if x - y = 2 and x<sup>2</sup>  - y<sup>2</sup>  = 8",
    "option": {
      "a": " (-1, 3)",
      "b": "(3, 1)",
      "c": " (-3, 1)",
      "d": "(1, 3)",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "b",
    "solution": "x - y = 2 ...........(1)\n\nx2 - y2 = 8 ........... (2)\n\nx - 2 = y ............ (3)\n\nPut y = x -2 in (2)\n\nx2 - (x - 2)2 = 8\n\nx2 - (x2 - 4x + 4) = 8\n\nx2 - x2 + 4x - 4 = 8\n\n4x = 8 + 4 = 12\n\nx = 12/4\n\n= 3\n\nfrom (3), y = 3 - 2 = 1\n\ntherefore, x = 3, y = 1",
    "examtype": "utme",
    "examyear": "2010"
  }
