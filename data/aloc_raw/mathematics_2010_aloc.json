    "question": "A cylindrical pipe 50m long with radius 7m has one end open. What is the total surface area of the pipe?\n",
    "option": {
      "a": "749πm<sup>2</sup>",
      "b": "700πm<sup>2</sup>",
      "c": "350πm<sup>2</sup>",
      "d": "98πm<sup>2</sup>",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "a",
    "solution": "Total surface area of the cylindrical pipe = area of circular base + curved surface area\n\n= πr<sup>2</sup> + 2πrh\n\n= π x 7<sup>2</sup> + 2π x 7 x 50\n\n= 49π + 700π\n= 749πm<sup>2</sup>",
    "examtype": "utme",
    "examyear": "2010"
  },
