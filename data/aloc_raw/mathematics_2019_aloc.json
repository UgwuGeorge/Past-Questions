    "id": 1003,
    "question": "If S = (4t + 3)(t - 2), find ds/dt when t = 5 secs.",
    "option": {
      "a": "50 units per sec",
      "b": "35 units per sec",
      "c": "22 units per sec",
      "d": "13 units per sec",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "b",
    "solution": "s=(4t+3)(t−2)\n \nds/dt=(4t+3)(1)+(t−2)(4)\n= 4t+3+4t−8\n= 8t - 5\n\nds/dt(t=5secs)=8(5)−5\n= 40 - 5 \n\n= 35 units per sec",
    "examtype": "utme",
    "examyear": "2019"
  },
