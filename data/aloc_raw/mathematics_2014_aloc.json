    "question": "A woman bought a grinder for N60,000. She sold it at a loss of 15%. How much did she sell it?",
    "option": {
      "a": " N53,000",
      "b": "N52,000",
      "c": "N51,000",
      "d": "N50,000",
      "e": null
    },
    "section": "",
    "image": "",
    "answer": "c",
    "solution": "SP = Nx\nCP = N60,000\nPercentage loss = 15%\nUsing percentage loss...\n\n(CP−SP)/CP = 100%\n\n\n15% = (60000− x)/ 60000 × 100%\n\n\n15% × 60000=(60000−x)100%\n\n\n60000 − x = (15% × 60000)100%\n\n\n60000 - x = 3 x 3000\n\n60000 -x = 9000\n\nx = 60000 - 9000\n\nx = N51,000",
    "examtype": "utme",
    "examyear": "2014"
  },
